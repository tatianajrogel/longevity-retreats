# Production environment variables for VPS deployment.
# Copy to .env.production.local on the server (gitignored — never commit real values).
# See DEPLOY.md for the full setup walkthrough.

# ─── Supabase ────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Service role key — server-only, bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── Database (for npm run db:apply) ─────────────────────────────────────────
# From: Supabase Dashboard → Connect → Session pooler URI
DATABASE_URL=postgresql://postgres.ref:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Admin panel ─────────────────────────────────────────────────────────────
# Strong random passphrase — both vars must match.
# NEXT_PUBLIC_ is used for client-side login validation.
ADMIN_CODE=change-me-strong-passphrase
NEXT_PUBLIC_ADMIN_CODE=change-me-strong-passphrase

# ─── Google Sheets sync ───────────────────────────────────────────────────────
# Random secret to authenticate POST /api/sync — generate with: openssl rand -hex 32
SYNC_SECRET=

# Cron schedule for auto-sync (node-cron syntax). Default: every hour.
SYNC_CRON_SCHEDULE=0 * * * *

# Google Sheet ID from the URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=

# GCP service account key JSON — paste as a single minified line.
# Steps: GCP Console → IAM → Service Accounts → Keys → Add Key → JSON
#        Then share the Sheet with the service account email (Viewer role).
#        Minify with: jq -c . service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
