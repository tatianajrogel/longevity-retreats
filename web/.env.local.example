# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# ─── Supabase ────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Service role key — server-only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── Database (for npm run db:apply) ─────────────────────────────────────────
# From: Supabase Dashboard → Connect → Session pooler
DATABASE_URL=postgresql://postgres.ref:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Admin panel ─────────────────────────────────────────────────────────────
# Both must match. NEXT_PUBLIC_ is used for client-side validation.
ADMIN_CODE=change-me
NEXT_PUBLIC_ADMIN_CODE=change-me

# ─── Google Sheets sync ───────────────────────────────────────────────────────
# Random secret to authenticate POST /api/sync  (e.g. openssl rand -hex 16)
SYNC_SECRET=

# Cron schedule (default: every hour). Uses node-cron syntax. VPS only.
SYNC_CRON_SCHEDULE=0 * * * *

# Google Sheet ID from the URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=

# GCP service account key JSON — paste as a single minified line
# Steps: GCP Console → IAM → Service Accounts → Keys → Add Key → JSON
#        Then share the Sheet with the service account email (read-only)
GOOGLE_SERVICE_ACCOUNT_JSON=

# ─── Newsletter (Beehiiv) ──────────────────────────────────────────────────────
# From: Beehiiv Dashboard → Settings → API
BEEHIIV_PUBLICATION_ID=pub_...
BEEHIIV_API_KEY=

# ─── Google Analytics 4 ───────────────────────────────────────────────────────
# From: GA4 → Admin → Data Streams → Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=
